<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/rootLayout"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Фиксированная Шапка Таблицы -->
    <LinearLayout
        android:id="@+id/headerLayout"
        android:background="#E0E0E0"
        android:padding="8dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_weight="4"
            android:text="Вопросы" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="📷" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_weight="2"
            android:text="Цель" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_weight="2"
            android:text="Ответ" />
    </LinearLayout>

    <!-- Прокручиваемый список вопросов -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerViewQuestions"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="#FFFFFF"/>

    <!-- Закреплённый нижний блок действий -->
    <LinearLayout
        android:id="@+id/actionBlock"
        android:orientation="vertical"
        android:background="#F5F5F5"
        android:padding="8dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- Поле для комментария -->
        <EditText
            android:id="@+id/commentEditText"
            android:hint="Введите комментарий"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@android:drawable/edit_text"
            android:padding="8dp"/>

        <!-- Контейнер для динамических кнопок -->
        <LinearLayout
            android:id="@+id/actionButtonContainer"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingTop="8dp"
            android:paddingBottom="8dp">
            <!-- Тут будут динамически добавляться кнопки -->
        </LinearLayout>
    </LinearLayout>

</LinearLayout>
